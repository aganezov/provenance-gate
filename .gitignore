# Python
__pycache__/
*.py[cod]
.venv/
.uv/
*.egg-info/
build/
dist/
.pytest_cache/
.ruff_cache/

# Claude Code (local, per-user — shared settings.json is tracked)
.claude/settings.local.json

# Runtime / scratch
*.db
# ...but keep the one committed demo capture (the loop-closure example) tracked:
!evals/claude-science-rollouts/examples/pbmc-version-mix/project.db
# gate per-project state dir (sidecars + append-only logs) — set PG_STATE_DIR to relocate
.pg/
.playwright-mcp/

# Claude Design pipeline — the mock AND its fixtures are disposable/derived: regenerated from CS by
# design/graph_fixtures.py + design/build_mock.py. The pipeline scripts + brief stay tracked; not the data.
ui/cockpit.mock.html
design/graph_fixtures.json
design/cs-shots/
# raw fetched libs — staging for design/vendor_libs.py; the served copy is inlined into ui/cockpit.html
ui/vendor/

# Built CS skill bundle (design/build_skill.py output) — generated kernel.py/SKILL.md + zip; not tracked
design/skill_dist/

# Cross-session idea scratch — persistent notes/ideas we collect (incl. from other sessions); not tracked
ideas/

# Eval harness (evals/) — never commit raw run evidence, the Node subpackage's deps, or browser
# auth/session/profile state (sensitive). The harness sets exact profile/auth dir names; these
# anticipate the common ones so nothing sensitive is committed even on first creation.
evals/*/runs/
node_modules/
evals/**/.auth/
evals/**/browser-profile/

# OS
.DS_Store
